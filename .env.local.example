# ============================================================
# EDUHUB Environment Variables
# Copy this file to .env.local and fill in your keys
# ============================================================

# ─── AI PROVIDERS (add at least ONE) ────────────────────────
# Priority order: Gemini → Groq → OpenAI (auto-fallback)

# 1. Google Gemini (RECOMMENDED — best quality, free tier)
#    Get key: https://aistudio.google.com/app/apikey
#    Free: 1 million tokens/day, 15 requests/minute
GEMINI_API_KEY=

# 2. Groq (FASTEST — LLaMA 3.3 70B, very generous free tier)
#    Get key: https://console.groq.com/keys
#    Free: 14,400 requests/day, 30 requests/minute
GROQ_API_KEY=

# 3. OpenAI (FALLBACK — GPT-4o mini, paid)
#    Get key: https://platform.openai.com/api-keys
#    Cost: ~$0.001 per question set
OPENAI_API_KEY=

# ─── SUPABASE (REQUIRED) ────────────────────────────────────
# Get from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...

# ─── PUSHER (Optional — for Battle Mode) ────────────────────
# Get from: https://pusher.com → Create App
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=ap2
PUSHER_APP_ID=
PUSHER_SECRET=

# ─── RAZORPAY (Optional — for Payments) ─────────────────────
# Get from: https://razorpay.com → Settings → API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=

# ─── APP ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
